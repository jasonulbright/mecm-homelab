    if (($DHCP -or $performAll) -and (Get-LabVM -Role DHCP | Where-Object { -not $_.SkipDeployment }))
    {
        Write-ScreenInfo -Message 'Configuring DHCP servers' -TaskStart

        $dhcpMachines = Get-LabVM -Role DHCP | Where-Object { -not $_.SkipDeployment }
        foreach ($dhcpMachine in $dhcpMachines)
        {
            $role = $dhcpMachine.Roles | Where-Object { $_.Name -eq 'DHCP' }
            $props = $role.Properties

            Invoke-LabCommand -ComputerName $dhcpMachine -ActivityName 'Install and configure DHCP' -ScriptBlock {
                param($ScopeStart, $ScopeEnd, $SubnetMask, $DnsDomain, $DnsServer, $Router, $ScopeName)
                if (-not (Get-WindowsFeature DHCP).Installed) {
                    Install-WindowsFeature DHCP -IncludeManagementTools | Out-Null
                }
                $fqdn = "$env:COMPUTERNAME.$DnsDomain"
                $existing = Get-DhcpServerInDC -ErrorAction SilentlyContinue | Where-Object { $_.DnsName -eq $fqdn }
                if (-not $existing) { Add-DhcpServerInDC -DnsName $fqdn -ErrorAction SilentlyContinue }
                Set-ItemProperty -Path 'HKLM:\SOFTWARE\Microsoft\ServerManager\Roles\12' -Name 'ConfigurationState' -Value 2 -ErrorAction SilentlyContinue
                if (-not $ScopeName) { $ScopeName = 'LabScope' }
                $scopeId = ($ScopeStart -replace '\.\d+$', '.0')
                $existingScope = Get-DhcpServerv4Scope -ErrorAction SilentlyContinue | Where-Object { $_.ScopeId -eq $scopeId }
                if (-not $existingScope) {
                    Add-DhcpServerv4Scope -Name $ScopeName -StartRange $ScopeStart -EndRange $ScopeEnd -SubnetMask $SubnetMask -State Active
                    Set-DhcpServerv4OptionValue -ScopeId $scopeId -DnsServer $DnsServer -DnsDomain $DnsDomain -Router $Router
                }
            } -ArgumentList $props.ScopeStart, $props.ScopeEnd, $props.SubnetMask, $props.DnsDomain, $props.DnsServer, $props.Router, $props.ScopeName
        }

        Write-ScreenInfo -Message 'Done' -TaskEnd
    }

